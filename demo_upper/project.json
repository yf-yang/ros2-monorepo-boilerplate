{
  "$schema": "https://raw.githubusercontent.com/nrwl/nx/master/packages/nx/schemas/project-schema.json",
  "name": "demo_upper",
  "projectType": "application",
  "root": "demo_upper",
  "sourceRoot": "demo_upper/src",
  "targets": {
    "format": {
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{workspaceRoot}/.oxfmtrc.json"
      ],
      "options": {
        "command": "pnpm exec oxfmt --check {projectRoot}/src"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{workspaceRoot}/.oxlintrc.json"
      ],
      "options": {
        "command": "pnpm exec oxlint --type-aware {projectRoot}/src"
      }
    },
    "cspell": {
      "executor": "nx:run-commands",
      "inputs": ["{projectRoot}/**", "{workspaceRoot}/.cspell.json"],
      "options": {
        "command": "cspell --no-progress --gitignore \"{projectRoot}/**\""
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "inputs": [
        "{projectRoot}/src/**",
        "{projectRoot}/tsconfig.json",
        "{workspaceRoot}/tsconfig.base.json"
      ],
      "options": {
        "command": "pnpm exec tsgo --noEmit --project {projectRoot}/tsconfig.json"
      }
    }
  }
}
