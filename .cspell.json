{
  "words": [
    "bringup",
    "bufbuild",
    "buildtool",
    "colcon",
    "copywrite",
    "fzstd",
    "libprotobuf",
    "mcap",
    "protoc",
    "pytest",
    "rclcpp",
    "rclpy",
    "rosout",
    "zenoh"
  ],
  "ignorePaths": [
    "*.code-workspace",
    "**/project.json",
    "**/CMakeLists.txt",
    "build",
    "dist",
    "generated",
    ".devcontainer",
    "ruff.toml",
    "ty.toml",
    "pixi.toml",
    ".clang-tidy",
    "*.lock",
    "package.xml"
  ],
  "ignoreRegExpList": [
    "comment-tags"
  ],
  "patterns": [
    {
      "name": "comment-tags",
      "pattern": "/(?:TODO|BUG|FIXME|XXX|HACK|NOTE)\\([-\\w\\.\\@,\\s\\&]*\\)/g"
    }
  ],
  "languageSettings": [
    {
      // use with Markdown files
      "languageId": "markdown",
      // Exclude code.
      "ignoreRegExpList": [
        "/^\\s*```[\\s\\S]*?^\\s*```/gm"
      ]
    }
  ],
  "import": []
}
